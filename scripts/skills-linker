#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEFAULT_SKILLS_ROOT="$ROOT_DIR/skills"
DEFAULT_PROJECT_ROOT="$PWD"
MANIFEST_FILENAME=".skills-linker-manifest.tsv"

usage() {
  cat <<'EOF'
Usage:
  skills-linker tools
  skills-linker list [--skills-root DIR] [--category NAME]
  skills-linker install|uninstall|status [options] [skill ...]
  skills-linker tui [options]

Options:
  --skills-root DIR      Skills root (default: repo ./skills)
  --category NAME        Filter skills by category: global|cron|auto|manual
  --tool NAME            codex|chatgpt|claude|amp|custom (default: codex)
  --scope SCOPE          global|project (default: global)
  --project-root DIR     Project root for project scope (default: current directory)
  --target-dir DIR       Explicit target skills directory
  --mode MODE            symlink|copy (install only, default: symlink)
  --auto-install-fzf     Allow installing fzf via Homebrew for tui command
  --force                Replace/remove conflicting targets
  --with-slash-commands  Also install slash command wrappers for manual skills
                         (claude→~/.claude/commands, codex→~/.codex/prompts)
  --json                 JSON output (list/status/install/uninstall)

Requires: fzf (for tui command)
EOF
}

die() {
  echo "error: $*" >&2
  exit 1
}

ensure_fzf() {
  local auto_install="${1:-0}"
  command -v fzf >/dev/null 2>&1 && return 0
  if [[ "$auto_install" != "1" ]]; then
    die "fzf not found. Install it manually (https://github.com/junegunn/fzf#installation) or rerun with --auto-install-fzf"
  fi
  echo "fzf not found. Installing via Homebrew..." >&2
  if ! command -v brew >/dev/null 2>&1; then
    die "fzf not found and Homebrew is not installed. Please install fzf: https://github.com/junegunn/fzf#installation"
  fi
  brew install fzf || die "failed to install fzf"
}

array_contains() {
  local needle="$1"
  shift
  local item
  for item in "$@"; do
    if [[ "$item" == "$needle" ]]; then
      return 0
    fi
  done
  return 1
}

resolve_target_dir() {
  local tool="$1"
  local scope="$2"
  local project_root="$3"
  local override="${4:-}"
  if [[ -n "$override" ]]; then
    echo "$override"
    return 0
  fi

  case "$tool" in
    codex|chatgpt)
      if [[ "$scope" == "global" ]]; then
        echo "$HOME/.codex/skills"
      else
        echo "$project_root/.codex/skills"
      fi
      ;;
    claude|claude-code)
      if [[ "$scope" == "global" ]]; then
        echo "$HOME/.claude/skills"
      else
        echo "$project_root/.claude/skills"
      fi
      ;;
    amp)
      if [[ "$scope" == "global" ]]; then
        echo "$HOME/.agents/skills"
      else
        echo "$project_root/.agents/skills"
      fi
      ;;
    custom)
      die "tool=custom requires --target-dir"
      ;;
    *)
      die "unsupported tool: $tool"
      ;;
  esac
}

discover_skills() {
  local skills_root="$1"
  [[ -d "$skills_root" ]] || return 0
  local dir
  while IFS= read -r dir; do
    basename "$dir"
  done < <(discover_skill_dirs "$skills_root")
}

discover_skill_dirs() {
  local skills_root="$1"
  [[ -d "$skills_root" ]] || return 0
  find "$skills_root" -type f -name SKILL.md -print \
    | sed 's#/SKILL\.md$##' \
    | sort
}

resolve_skill_dir() {
  local skills_root="$1"
  local skill_id="$2"
  local dir
  while IFS= read -r dir; do
    if [[ "$(basename "$dir")" == "$skill_id" ]]; then
      echo "$dir"
      return 0
    fi
  done < <(discover_skill_dirs "$skills_root")
  return 1
}

skill_relative_path() {
  local skills_root="$1"
  local skill_dir="$2"
  printf '%s\n' "${skill_dir#$skills_root/}"
}

yaml_top_level_scalar() {
  local yaml_file="$1"
  local key="$2"
  [[ -f "$yaml_file" ]] || return 0
  awk -F ':' -v key="$key" '
    /^[[:space:]]*#/ { next }
    $0 ~ "^[[:space:]]*" key ":[[:space:]]*" {
      sub("^[^:]*:[[:space:]]*", "", $0)
      print $0
      exit
    }
  ' "$yaml_file"
}

skill_title() {
  local skill_dir="$1"
  yaml_top_level_scalar "$skill_dir/skill.yaml" "title"
}

skill_summary() {
  local skill_dir="$1"
  yaml_top_level_scalar "$skill_dir/skill.yaml" "summary"
}

skill_manual_group() {
  local skills_root="$1"
  local skill_dir="$2"
  local rel_path first second
  rel_path="$(skill_relative_path "$skills_root" "$skill_dir")"
  IFS='/' read -r first second _ <<<"$rel_path"
  if [[ "$first" == "manual" && -n "$second" ]]; then
    echo "$second"
    return 0
  fi
  yaml_top_level_scalar "$skill_dir/skill.yaml" "manual_group"
}

skill_category() {
  local skills_root="$1"
  local skill_dir="$2"
  local yaml_file="$skill_dir/skill.yaml"
  local category activation rel_path first
  rel_path="$(skill_relative_path "$skills_root" "$skill_dir")"
  IFS='/' read -r first _ <<<"$rel_path"
  case "$first" in
    global|cron|auto|manual)
      echo "$first"
      return 0
      ;;
  esac
  category="$(yaml_top_level_scalar "$yaml_file" "category")"
  if [[ -n "$category" ]]; then
    echo "$category"
    return 0
  fi

  activation="$(yaml_top_level_scalar "$yaml_file" "activation")"
  case "$activation" in
    always_on) echo "auto" ;;
    cron|scheduled) echo "cron" ;;
    global|auto|manual) echo "$activation" ;;
    *) echo "manual" ;;
  esac
}

validate_category() {
  local category="${1:-}"
  case "$category" in
    ""|global|cron|auto|manual) return 0 ;;
    *) die "unsupported category: $category" ;;
  esac
}

is_auto_injected_skill() {
  local skills_root="$1"
  local skill_dir="$2"
  local category
  category="$(skill_category "$skills_root" "$skill_dir")"
  [[ "$category" == "global" || "$category" == "auto" ]]
}

manifest_path() {
  local target_dir="$1"
  echo "$target_dir/$MANIFEST_FILENAME"
}

manifest_get_mode() {
  local target_dir="$1"
  local skill_id="$2"
  local file
  file="$(manifest_path "$target_dir")"
  [[ -f "$file" ]] || return 0
  awk -F '\t' -v skill="$skill_id" '$1 == skill {print $2}' "$file" | tail -n1
}

manifest_upsert() {
  local target_dir="$1"
  local skill_id="$2"
  local mode="$3"
  local source="$4"
  local file tmp
  file="$(manifest_path "$target_dir")"
  mkdir -p "$target_dir"
  tmp="$(mktemp)"
  if [[ -f "$file" ]]; then
    awk -F '\t' -v skill="$skill_id" '$1 != skill {print $0}' "$file" >"$tmp"
  fi
  printf "%s\t%s\t%s\t%s\n" "$skill_id" "$mode" "$source" "$(date -u +%FT%TZ)" >>"$tmp"
  mv "$tmp" "$file"
}

manifest_remove() {
  local target_dir="$1"
  local skill_id="$2"
  local file tmp
  file="$(manifest_path "$target_dir")"
  [[ -f "$file" ]] || return 0
  tmp="$(mktemp)"
  awk -F '\t' -v skill="$skill_id" '$1 != skill {print $0}' "$file" >"$tmp"
  if [[ -s "$tmp" ]]; then
    mv "$tmp" "$file"
  else
    rm -f "$tmp" "$file"
  fi
}

resolve_instruction_file() {
  local tool="$1"
  local scope="$2"
  local project_root="$3"
  case "$tool" in
    claude|claude-code)
      if [[ "$scope" == "global" ]]; then
        echo "$HOME/.claude/CLAUDE.md"
      else
        echo "$project_root/CLAUDE.md"
      fi
      ;;
    codex|chatgpt)
      if [[ "$scope" == "global" ]]; then
        echo "$HOME/.codex/AGENTS.md"
      else
        echo "$project_root/AGENTS.md"
      fi
      ;;
    amp)
      if [[ "$scope" == "global" ]]; then
        echo "$HOME/.config/amp/AGENTS.md"
      else
        echo "$project_root/AGENTS.md"
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

inject_always_on() {
  local skill_id="$1"
  local skill_dir="$2"
  local instruction_file="$3"
  local inject_file="$skill_dir/inject.md"
  [[ -f "$inject_file" ]] || return 0

  local begin_marker="<!-- skills-linker:${skill_id}:begin -->"
  local end_marker="<!-- skills-linker:${skill_id}:end -->"

  if [[ -f "$instruction_file" ]] && grep -qF "$begin_marker" "$instruction_file" 2>/dev/null; then
    return 1
  fi

  mkdir -p "$(dirname "$instruction_file")"
  {
    if [[ -f "$instruction_file" ]] && [[ -s "$instruction_file" ]]; then
      printf '\n'
    fi
    printf '%s\n' "$begin_marker"
    cat "$inject_file"
    printf '%s\n' "$end_marker"
  } >> "$instruction_file"
}

remove_always_on() {
  local skill_id="$1"
  local instruction_file="$2"
  [[ -f "$instruction_file" ]] || return 0

  local begin_marker="<!-- skills-linker:${skill_id}:begin -->"
  local end_marker="<!-- skills-linker:${skill_id}:end -->"
  grep -qF "$begin_marker" "$instruction_file" 2>/dev/null || return 0

  local tmp
  tmp="$(mktemp)"
  awk -v begin="$begin_marker" -v end="$end_marker" '
    $0 == begin { skip=1; next }
    $0 == end   { skip=0; next }
    !skip       { print }
  ' "$instruction_file" > "$tmp"

  # Remove trailing blank lines (POSIX compatible — works on macOS BSD and GNU)
  awk '{lines[NR]=$0} /./{last=NR} END{for(i=1;i<=last;i++)print lines[i]}' "$tmp" > "$instruction_file"
  rm -f "$tmp"

  # Clean up empty instruction file
  if [[ -f "$instruction_file" ]] && [[ ! -s "$instruction_file" ]]; then
    rm -f "$instruction_file"
  fi
}

handle_always_on_install() {
  local skills_root="$1"
  local tool="$2"
  local scope="$3"
  local project_root="$4"
  shift 4
  local skills=("$@")

  local instruction_file
  instruction_file="$(resolve_instruction_file "$tool" "$scope" "$project_root")" || return 0

  local skill source
  for skill in "${skills[@]}"; do
    source="$(resolve_skill_dir "$skills_root" "$skill")" || continue
    if is_auto_injected_skill "$skills_root" "$source"; then
      if inject_always_on "$skill" "$source" "$instruction_file"; then
        echo "$skill: injected always-on instruction → $instruction_file"
      else
        echo "$skill: always-on instruction already present in $instruction_file"
      fi
    fi
  done
}

handle_always_on_uninstall() {
  local skills_root="$1"
  local tool="$2"
  local scope="$3"
  local project_root="$4"
  shift 4
  local skills=("$@")

  local instruction_file
  instruction_file="$(resolve_instruction_file "$tool" "$scope" "$project_root")" || return 0

  local skill source
  for skill in "${skills[@]}"; do
    source="$(resolve_skill_dir "$skills_root" "$skill")" || continue
    if is_auto_injected_skill "$skills_root" "$source"; then
      remove_always_on "$skill" "$instruction_file"
      echo "$skill: removed always-on instruction ← $instruction_file"
    fi
  done
}

resolve_slash_command_dir() {
  local tool="$1"
  local scope="$2"
  local project_root="$3"
  case "$tool" in
    claude|claude-code)
      if [[ "$scope" == "global" ]]; then
        echo "$HOME/.claude/commands"
      else
        echo "$project_root/.claude/commands"
      fi
      ;;
    codex|chatgpt)
      if [[ "$scope" == "global" ]]; then
        echo "$HOME/.codex/prompts"
      else
        echo "$project_root/.codex/prompts"
      fi
      ;;
    *)
      return 1
      ;;
  esac
}

is_manual_skill() {
  local skills_root="$1"
  local skill_dir="$2"
  [[ "$(skill_category "$skills_root" "$skill_dir")" == "manual" ]]
}

write_slash_command_file() {
  local tool="$1"
  local skill_id="$2"
  local skill_dir="$3"
  local skills_root="$4"
  local file="$5"
  local rel_path summary
  rel_path="$(skill_relative_path "$skills_root" "$skill_dir")"
  summary="$(skill_summary "$skill_dir")"
  [[ -n "$summary" ]] || summary="Invoke the $skill_id skill"

  case "$tool" in
    claude|claude-code)
      cat >"$file" <<EOF
---
description: ${summary}
argument-hint: [extra context]
---
<!-- skills-linker:slash:${skill_id} -->

Use the \`${skill_id}\` skill for this request. Read its definition at:
skills/${rel_path}/SKILL.md

\$ARGUMENTS
EOF
      ;;
    codex|chatgpt)
      cat >"$file" <<EOF
<!-- skills-linker:slash:${skill_id} -->

Use the \`${skill_id}\` skill for this request. Read its definition at:
skills/${rel_path}/SKILL.md
EOF
      ;;
    *)
      return 1
      ;;
  esac
}

install_slash_command() {
  local skills_root="$1"
  local skill_id="$2"
  local skill_dir="$3"
  local slash_dir="$4"
  local tool="$5"
  local force="$6"
  local file="$slash_dir/$skill_id.md"
  local marker="<!-- skills-linker:slash:${skill_id} -->"

  if [[ -e "$file" ]]; then
    if grep -qF "$marker" "$file" 2>/dev/null; then
      :  # already managed — safe to refresh
    elif [[ "$force" == "1" ]]; then
      :  # user explicitly opted to overwrite
    else
      return 1  # foreign file, leave alone
    fi
  fi

  mkdir -p "$slash_dir"
  write_slash_command_file "$tool" "$skill_id" "$skill_dir" "$skills_root" "$file"
}

remove_slash_command() {
  local skill_id="$1"
  local slash_dir="$2"
  local file="$slash_dir/$skill_id.md"
  local marker="<!-- skills-linker:slash:${skill_id} -->"
  [[ -f "$file" ]] || return 0
  if grep -qF "$marker" "$file" 2>/dev/null; then
    rm -f "$file"
    return 0
  fi
  return 1
}

handle_slash_install() {
  local skills_root="$1"
  local tool="$2"
  local scope="$3"
  local project_root="$4"
  local force="$5"
  shift 5
  local skills=("$@")

  local slash_dir
  slash_dir="$(resolve_slash_command_dir "$tool" "$scope" "$project_root")" || {
    echo "slash commands not supported for tool=$tool"
    return 0
  }

  local skill source
  for skill in "${skills[@]}"; do
    source="$(resolve_skill_dir "$skills_root" "$skill")" || continue
    is_manual_skill "$skills_root" "$source" || continue
    if install_slash_command "$skills_root" "$skill" "$source" "$slash_dir" "$tool" "$force"; then
      echo "$skill: slash command installed → $slash_dir/$skill.md"
    else
      echo "$skill: slash command exists at $slash_dir/$skill.md (use --force to overwrite)"
    fi
  done
}

handle_slash_uninstall() {
  local skills_root="$1"
  local tool="$2"
  local scope="$3"
  local project_root="$4"
  shift 4
  local skills=("$@")

  local slash_dir
  slash_dir="$(resolve_slash_command_dir "$tool" "$scope" "$project_root")" || return 0

  local skill file
  for skill in "${skills[@]}"; do
    file="$slash_dir/$skill.md"
    [[ -f "$file" ]] || continue
    if remove_slash_command "$skill" "$slash_dir"; then
      echo "$skill: removed slash command ← $file"
    else
      echo "$skill: slash command at $file is not managed by linker, leaving in place"
    fi
  done
}

print_json_results() {
  local action="$1"
  local skills_root="$2"
  local target_dir="$3"
  local result_lines="$4"
  json_escape() {
    printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e $'s/\t/\\\\t/g' -e $'s/\r/\\\\r/g' | tr '\n' ' '
  }

  printf '{\n'
  printf '  "action": "%s",\n' "$(json_escape "$action")"
  printf '  "skills_root": "%s",\n' "$(json_escape "$skills_root")"
  printf '  "target_dir": "%s",\n' "$(json_escape "$target_dir")"
  printf '  "results": [\n'
  local first=1
  local skill status reason
  while IFS=$'\t' read -r skill status reason; do
    [[ -n "$skill" ]] || continue
    if [[ "$first" -eq 0 ]]; then
      printf ',\n'
    fi
    first=0
    printf '    {"skill":"%s","status":"%s"' "$(json_escape "$skill")" "$(json_escape "$status")"
    if [[ -n "${reason:-}" ]]; then
      printf ',"reason":"%s"' "$(json_escape "$reason")"
    fi
    printf '}'
  done <<<"$result_lines"
  printf '\n'
  printf '  ]\n'
  printf '}\n'
}

run_install() {
  local skills_root="$1"
  local target_dir="$2"
  local mode="$3"
  local force="$4"
  local as_json="$5"
  shift 5
  local selected=("$@")

  mkdir -p "$target_dir"
  local out=()
  local skill source dest
  for skill in "${selected[@]}"; do
    source="$(resolve_skill_dir "$skills_root" "$skill" || true)"
    dest="$target_dir/$skill"
    if [[ ! -d "$source" || ! -f "$source/SKILL.md" ]]; then
      out+=("$skill"$'\t'"error"$'\t'"skill not found")
      continue
    fi

    if [[ -e "$dest" || -L "$dest" ]]; then
      if [[ "$force" == "1" ]]; then
        rm -rf "$dest"
      else
        out+=("$skill"$'\t'"skip"$'\t'"path exists")
        continue
      fi
    fi

    if [[ "$mode" == "symlink" ]]; then
      ln -s "$source" "$dest"
    else
      cp -R "$source" "$dest"
    fi
    manifest_upsert "$target_dir" "$skill" "$mode" "$source"
    out+=("$skill"$'\t'"installed")
  done

  local lines
  lines="$(printf "%s\n" "${out[@]}")"
  if [[ "$as_json" == "1" ]]; then
    print_json_results "install" "$skills_root" "$target_dir" "$lines"
  else
    echo "target: $target_dir"
    echo "mode: $mode"
    local line
    while IFS=$'\t' read -r skill status reason; do
      [[ -n "$skill" ]] || continue
      if [[ -n "${reason:-}" ]]; then
        echo "$skill: $status ($reason)"
      else
        echo "$skill: $status"
      fi
    done <<<"$lines"
  fi
}

run_uninstall() {
  local skills_root="$1"
  local target_dir="$2"
  local force="$3"
  local as_json="$4"
  shift 4
  local selected=("$@")

  local out=()
  local skill dest mode_from_manifest
  for skill in "${selected[@]}"; do
    dest="$target_dir/$skill"
    if [[ ! -e "$dest" && ! -L "$dest" ]]; then
      manifest_remove "$target_dir" "$skill"
      out+=("$skill"$'\t'"missing")
      continue
    fi

    mode_from_manifest="$(manifest_get_mode "$target_dir" "$skill")"
    if [[ "$force" == "1" || -n "$mode_from_manifest" ]]; then
      rm -rf "$dest"
      manifest_remove "$target_dir" "$skill"
      out+=("$skill"$'\t'"removed")
    else
      out+=("$skill"$'\t'"skip"$'\t'"not managed by linker (use --force)")
    fi
  done

  local lines
  lines="$(printf "%s\n" "${out[@]}")"
  if [[ "$as_json" == "1" ]]; then
    print_json_results "uninstall" "$skills_root" "$target_dir" "$lines"
  else
    echo "target: $target_dir"
    local line
    while IFS=$'\t' read -r skill status reason; do
      [[ -n "$skill" ]] || continue
      if [[ -n "${reason:-}" ]]; then
        echo "$skill: $status ($reason)"
      else
        echo "$skill: $status"
      fi
    done <<<"$lines"
  fi
}

run_status() {
  local skills_root="$1"
  local target_dir="$2"
  local as_json="$3"
  shift 3
  local selected=("$@")
  local out=()
  local skill dest state managed
  for skill in "${selected[@]}"; do
    dest="$target_dir/$skill"
    if [[ -L "$dest" ]]; then
      state="symlink"
    elif [[ -d "$dest" ]]; then
      state="directory"
    elif [[ -e "$dest" ]]; then
      state="file"
    else
      state="missing"
    fi
    if [[ -n "$(manifest_get_mode "$target_dir" "$skill")" ]]; then
      managed="true"
    else
      managed="false"
    fi
    out+=("$skill"$'\t'"$state"$'\t'"managed=$managed")
  done

  local lines
  lines="$(printf "%s\n" "${out[@]}")"
  if [[ "$as_json" == "1" ]]; then
    print_json_results "status" "$skills_root" "$target_dir" "$lines"
  else
    echo "target: $target_dir"
    local line
    while IFS=$'\t' read -r skill status reason; do
      [[ -n "$skill" ]] || continue
      echo "$skill: $status ($reason)"
    done <<<"$lines"
  fi
}

select_with_fzf() {
  local prompt="$1"
  shift
  printf "%s\n" "$@" | fzf --prompt="$prompt " --height=45% --layout=reverse --border --info=inline
}

choose_target_profile() {
  local project_root="$1"
  local choice
  choice="$(
    select_with_fzf "target>" \
      "codex/global (recommended)" \
      "codex/project" \
      "chatgpt/global" \
      "chatgpt/project" \
      "claude/global" \
      "claude/project" \
      "amp/global" \
      "amp/project" \
      "custom/path"
  )" || return 1

  local tool scope target_dir
  case "$choice" in
    "codex/global (recommended)") tool="codex"; scope="global"; target_dir="" ;;
    "codex/project") tool="codex"; scope="project"; target_dir="" ;;
    "chatgpt/global") tool="chatgpt"; scope="global"; target_dir="" ;;
    "chatgpt/project") tool="chatgpt"; scope="project"; target_dir="" ;;
    "claude/global") tool="claude"; scope="global"; target_dir="" ;;
    "claude/project") tool="claude"; scope="project"; target_dir="" ;;
    "amp/global") tool="amp"; scope="global"; target_dir="" ;;
    "amp/project") tool="amp"; scope="project"; target_dir="" ;;
    "custom/path")
      tool="custom"
      scope="global"
      read -r -p "target dir> " target_dir
      [[ -n "$target_dir" ]] || die "target dir is required for custom/path"
      ;;
    *)
      die "invalid target profile: $choice"
      ;;
  esac
  printf "%s|%s|%s\n" "$tool" "$scope" "$target_dir"
}

choose_install_policy() {
  local policy
  policy="$(
    select_with_fzf "install-policy>" \
      "safe-symlink (recommended)" \
      "safe-copy" \
      "force-symlink" \
      "force-copy"
  )" || return 1
  case "$policy" in
    "safe-symlink (recommended)") printf "symlink|0\n" ;;
    "safe-copy") printf "copy|0\n" ;;
    "force-symlink") printf "symlink|1\n" ;;
    "force-copy") printf "copy|1\n" ;;
    *) die "invalid install policy: $policy" ;;
  esac
}

choose_uninstall_force() {
  local policy
  policy="$(select_with_fzf "uninstall-policy>" "safe (managed only, recommended)" "force (remove all selected)")" || return 1
  if [[ "$policy" == "force (remove all selected)" ]]; then
    echo "1"
    return 0
  fi
  echo "0"
}

choose_skills_multi() {
  local skills_root="$1"
  local default_select_all="$2"
  shift 2
  local all_skills=("$@")
  local preview_cmd="dir=\$(find \"${skills_root}\" -type f -path \"*/{}/SKILL.md\" -print | head -n1 | sed 's#/SKILL.md\$##'); cat \"\$dir/SKILL.md\" 2>/dev/null || echo 'No SKILL.md found'"
  if [[ "$default_select_all" == "1" ]]; then
    printf "%s\n" "${all_skills[@]}" \
      | fzf --multi --bind "start:select-all" --prompt="skills> " --height=75% --layout=reverse --border --info=inline \
          --header="Tab mark | Enter confirm | install 默认全选" \
          --preview "$preview_cmd" --preview-window "right,60%,wrap"
    return $?
  fi
  printf "%s\n" "${all_skills[@]}" \
    | fzf --multi --prompt="skills> " --height=75% --layout=reverse --border --info=inline \
        --header="Tab mark | Enter confirm" \
        --preview "$preview_cmd" --preview-window "right,60%,wrap"
}

run_shell_tui() {
  local skills_root="$1"
  local project_root="$2"
  local tool="$3"
  local scope="$4"
  local mode="$5"
  local force="$6"
  local target_dir_override="$7"
  local auto_install_fzf="$8"
  local with_slash_commands="${9:-0}"

  ensure_fzf "$auto_install_fzf"

  local all_skills=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && all_skills+=("$line")
  done < <(discover_skills "$skills_root")
  [[ "${#all_skills[@]}" -gt 0 ]] || die "no skills found under $skills_root"

  local action="install"
  local selected=("${all_skills[@]}")

  while true; do
    local target_dir
    target_dir="$(resolve_target_dir "$tool" "$scope" "$project_root" "$target_dir_override")"

    local scope_label="$tool/$scope"
    if [[ -n "$target_dir_override" ]]; then
      scope_label="$scope_label (custom)"
    fi

    local policy_label
    if [[ "$action" == "install" ]]; then
      policy_label="mode=$mode force=$force slash=$with_slash_commands"
    elif [[ "$action" == "uninstall" ]]; then
      policy_label="force=$force"
    else
      policy_label="-"
    fi

    local header
    header=$'Enter=select\n'
    header+="action: $action"$'\n'
    header+="target: $scope_label"$'\n'
    header+="target_dir: $target_dir"$'\n'
    header+="policy: $policy_label"$'\n'
    header+="skills: ${#selected[@]}/${#all_skills[@]}"

    local choice
    choice="$(
      printf "%s\n" \
        "execute now" \
        "change action" \
        "change target" \
        "change policy" \
        "select skills" \
        "select all skills" \
        "clear selected skills" \
        "quit" \
      | fzf --prompt="tui> " --height=65% --layout=reverse --border --info=inline --header "$header"
    )" || return 1

    case "$choice" in
      "execute now")
        if [[ "${#selected[@]}" -eq 0 ]]; then
          echo "No skills selected. Please select skills first."
          read -r -p "Press Enter to continue... " _
          continue
        fi
        echo ""
        echo "action: $action"
        echo "target: $target_dir"
        echo "selected skills: ${#selected[@]}"
        case "$action" in
          install)
            run_install "$skills_root" "$target_dir" "$mode" "$force" "0" "${selected[@]}"
            handle_always_on_install "$skills_root" "$tool" "$scope" "$project_root" "${selected[@]}"
            if [[ "$with_slash_commands" == "1" ]]; then
              handle_slash_install "$skills_root" "$tool" "$scope" "$project_root" "$force" "${selected[@]}"
            fi
            ;;
          uninstall)
            run_uninstall "$skills_root" "$target_dir" "$force" "0" "${selected[@]}"
            handle_always_on_uninstall "$skills_root" "$tool" "$scope" "$project_root" "${selected[@]}"
            handle_slash_uninstall "$skills_root" "$tool" "$scope" "$project_root" "${selected[@]}"
            ;;
          status)
            run_status "$skills_root" "$target_dir" "0" "${selected[@]}"
            ;;
        esac
        echo ""
        read -r -p "Press Enter to continue... " _
        ;;
      "change action")
        local next_action
        next_action="$(select_with_fzf "action>" "install (recommended)" uninstall status)" || continue
        if [[ "$next_action" == "install (recommended)" ]]; then
          action="install"
          if [[ "${#selected[@]}" -eq 0 ]]; then
            selected=("${all_skills[@]}")
          fi
        else
          action="$next_action"
        fi
        ;;
      "change target")
        local profile_values
        profile_values="$(choose_target_profile "$project_root")" || continue
        tool="$(printf '%s' "$profile_values" | cut -d'|' -f1)"
        scope="$(printf '%s' "$profile_values" | cut -d'|' -f2)"
        local profile_target_override
        profile_target_override="$(printf '%s' "$profile_values" | cut -d'|' -f3-)"
        if [[ -n "$profile_target_override" ]]; then
          target_dir_override="$profile_target_override"
        else
          target_dir_override=""
        fi
        ;;
      "change policy")
        if [[ "$action" == "install" ]]; then
          local install_policy_values
          install_policy_values="$(choose_install_policy)" || continue
          mode="$(printf '%s' "$install_policy_values" | cut -d'|' -f1)"
          force="$(printf '%s' "$install_policy_values" | cut -d'|' -f2)"
          local slash_choice
          slash_choice="$(select_with_fzf "slash-commands>" "off (recommended)" "on (write /<name>.md wrappers)")" || continue
          if [[ "$slash_choice" == "on (write /<name>.md wrappers)" ]]; then
            with_slash_commands=1
          else
            with_slash_commands=0
          fi
        elif [[ "$action" == "uninstall" ]]; then
          force="$(choose_uninstall_force)" || continue
        else
          echo "Status action has no policy."
          read -r -p "Press Enter to continue... " _
        fi
        ;;
      "select skills")
        local selected_text
        if [[ "$action" == "install" && "${#selected[@]}" -eq 0 ]]; then
          selected_text="$(choose_skills_multi "$skills_root" "1" "${all_skills[@]}")" || continue
        else
          selected_text="$(choose_skills_multi "$skills_root" "0" "${all_skills[@]}")" || continue
        fi
        selected=()
        while IFS= read -r line; do
          [[ -n "$line" ]] && selected+=("$line")
        done <<<"$selected_text"
        ;;
      "select all skills")
        selected=("${all_skills[@]}")
        ;;
      "clear selected skills")
        selected=()
        ;;
      "quit")
        return 0
        ;;
      *)
        continue
        ;;
    esac
  done
}

cmd="${1:-}"
[[ -n "$cmd" ]] || {
  usage
  exit 2
}
shift || true

case "$cmd" in
  -h|--help|help)
    usage
    exit 0
    ;;
  tools)
    cat <<'EOF'
codex:
  global: ~/.codex/skills
  project: {project_root}/.codex/skills
chatgpt:
  global: ~/.codex/skills
  project: {project_root}/.codex/skills
claude:
  global: ~/.claude/skills
  project: {project_root}/.claude/skills
amp:
  global: ~/.agents/skills
  project: {project_root}/.agents/skills
aliases:
  chatgpt -> codex
  claude-code -> claude
EOF
    exit 0
    ;;
  list|install|uninstall|status|tui)
    ;;
  *)
    die "unknown command: $cmd"
    ;;
esac

skills_root="$DEFAULT_SKILLS_ROOT"
category_filter=""
tool="codex"
scope="global"
project_root="$DEFAULT_PROJECT_ROOT"
target_dir_override=""
mode="symlink"
force=0
as_json=0
auto_install_fzf=0
with_slash_commands=0
skills=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --skills-root)
      skills_root="$2"; shift 2 ;;
    --category)
      category_filter="$2"; shift 2 ;;
    --tool)
      tool="$2"; shift 2 ;;
    --scope)
      scope="$2"; shift 2 ;;
    --project-root)
      project_root="$2"; shift 2 ;;
    --target-dir)
      target_dir_override="$2"; shift 2 ;;
    --mode)
      mode="$2"; shift 2 ;;
    --auto-install-fzf)
      auto_install_fzf=1; shift ;;
    --force)
      force=1; shift ;;
    --with-slash-commands)
      with_slash_commands=1; shift ;;
    --json)
      as_json=1; shift ;;
    -h|--help)
      usage; exit 0 ;;
    --)
      shift
      while [[ $# -gt 0 ]]; do
        skills+=("$1")
        shift
      done
      ;;
    -*)
      die "unknown option: $1" ;;
    *)
      skills+=("$1")
      shift ;;
  esac
done

skills_root="$(cd "$skills_root" 2>/dev/null && pwd -P || echo "$skills_root")"
project_root="$(cd "$project_root" 2>/dev/null && pwd -P || echo "$project_root")"
validate_category "$category_filter"

if [[ "$cmd" == "list" ]]; then
  discovered=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && discovered+=("$line")
  done < <(discover_skills "$skills_root")
  if [[ -n "$category_filter" ]]; then
    filtered=()
    for skill in "${discovered[@]}"; do
      skill_dir="$(resolve_skill_dir "$skills_root" "$skill" || true)"
      if [[ -n "$skill_dir" && "$(skill_category "$skills_root" "$skill_dir")" == "$category_filter" ]]; then
        filtered+=("$skill")
      fi
    done
    discovered=("${filtered[@]}")
  fi
  if [[ "$as_json" == "1" ]]; then
    printf '{\n'
    printf '  "skills_root": "%s",\n' "$(printf '%s' "$skills_root" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
    if [[ -n "$category_filter" ]]; then
      printf '  "category_filter": "%s",\n' "$(printf '%s' "$category_filter" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
    fi
    printf '  "skills": [\n'
    for i in "${!discovered[@]}"; do
      skill_escaped="$(printf '%s' "${discovered[$i]}" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
      if [[ "$i" -gt 0 ]]; then
        printf ',\n'
      fi
      printf '    "%s"' "$skill_escaped"
    done
    printf '\n'
    printf '  ],\n'
    printf '  "items": [\n'
    for i in "${!discovered[@]}"; do
      skill="${discovered[$i]}"
      skill_dir="$(resolve_skill_dir "$skills_root" "$skill")"
      category="$(skill_category "$skills_root" "$skill_dir")"
      title="$(skill_title "$skill_dir")"
      summary="$(skill_summary "$skill_dir")"
      manual_group="$(skill_manual_group "$skills_root" "$skill_dir")"
      skill_path="$(skill_relative_path "$skills_root" "$skill_dir")"
      skill_escaped="$(printf '%s' "$skill" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
      skill_path_escaped="$(printf '%s' "$skill_path" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
      category_escaped="$(printf '%s' "$category" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
      title_escaped="$(printf '%s' "$title" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
      summary_escaped="$(printf '%s' "$summary" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
      manual_group_escaped="$(printf '%s' "$manual_group" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')"
      if [[ "$i" -gt 0 ]]; then
        printf ',\n'
      fi
      printf '    {"id":"%s","path":"%s","category":"%s","title":"%s","summary":"%s","manual_group":"%s"}' \
        "$skill_escaped" "$skill_path_escaped" "$category_escaped" "$title_escaped" "$summary_escaped" "$manual_group_escaped"
    done
    printf '\n'
    printf '  ],\n'
    printf '  "count": %d\n' "${#discovered[@]}"
    printf '}\n'
  else
    echo "skills root: $skills_root"
    if [[ -n "$category_filter" ]]; then
      echo "category: $category_filter"
    fi
    echo "count: ${#discovered[@]}"
    for category in global cron auto manual; do
      group=()
      for skill in "${discovered[@]}"; do
        skill_dir="$(resolve_skill_dir "$skills_root" "$skill" || true)"
        if [[ -n "$skill_dir" && "$(skill_category "$skills_root" "$skill_dir")" == "$category" ]]; then
          group+=("$skill")
        fi
      done
      [[ "${#group[@]}" -gt 0 ]] || continue
      echo ""
      echo "[$category]"
      for skill in "${group[@]}"; do
        skill_dir="$(resolve_skill_dir "$skills_root" "$skill")"
        title="$(skill_title "$skill_dir")"
        manual_group="$(skill_manual_group "$skills_root" "$skill_dir")"
        suffix=""
        if [[ "$category" == "manual" && -n "$manual_group" ]]; then
          suffix=" [$manual_group]"
        fi
        if [[ -n "$title" ]]; then
          echo "- $skill$suffix: $title"
        else
          echo "- $skill$suffix"
        fi
      done
    done
  fi
  exit 0
fi

if [[ "$cmd" == "tui" ]]; then
  run_shell_tui "$skills_root" "$project_root" "$tool" "$scope" "$mode" "$force" "$target_dir_override" "$auto_install_fzf" "$with_slash_commands"
  exit $?
fi

discovered=()
while IFS= read -r line; do
  [[ -n "$line" ]] && discovered+=("$line")
done < <(discover_skills "$skills_root")
if [[ -n "$category_filter" ]]; then
  filtered=()
  for skill in "${discovered[@]}"; do
    skill_dir="$(resolve_skill_dir "$skills_root" "$skill" || true)"
    if [[ -n "$skill_dir" && "$(skill_category "$skills_root" "$skill_dir")" == "$category_filter" ]]; then
      filtered+=("$skill")
    fi
  done
  discovered=("${filtered[@]}")
fi
if [[ "${#skills[@]}" -eq 0 ]]; then
  selected=("${discovered[@]}")
else
  selected=("${skills[@]}")
fi

if [[ "${#selected[@]}" -eq 0 ]]; then
  die "no skills found"
fi

for skill in "${selected[@]}"; do
  if ! array_contains "$skill" "${discovered[@]}"; then
    die "unknown skill id: $skill"
  fi
done

target_dir="$(resolve_target_dir "$tool" "$scope" "$project_root" "$target_dir_override")"
mkdir -p "$target_dir"

case "$cmd" in
  install)
    run_install "$skills_root" "$target_dir" "$mode" "$force" "$as_json" "${selected[@]}"
    handle_always_on_install "$skills_root" "$tool" "$scope" "$project_root" "${selected[@]}"
    if [[ "$with_slash_commands" == "1" ]]; then
      handle_slash_install "$skills_root" "$tool" "$scope" "$project_root" "$force" "${selected[@]}"
    fi
    ;;
  uninstall)
    run_uninstall "$skills_root" "$target_dir" "$force" "$as_json" "${selected[@]}"
    handle_always_on_uninstall "$skills_root" "$tool" "$scope" "$project_root" "${selected[@]}"
    handle_slash_uninstall "$skills_root" "$tool" "$scope" "$project_root" "${selected[@]}"
    ;;
  status)
    run_status "$skills_root" "$target_dir" "$as_json" "${selected[@]}"
    ;;
esac
