#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SKILLS_ROOT="$ROOT_DIR/skills"
LINKER="$ROOT_DIR/scripts/skills-linker"

usage() {
  cat <<'EOF'
Usage:
  ng                     Pick a manual skill interactively
  ng list                List manual skills
  ng plan                Show the category plan
  ng <skill-id>          Show how to trigger a specific skill

Notes:
  - `global` skills should be installed globally and auto-trigger after installation
  - `auto` skills auto-trigger after installation
  - `cron` skills are meant for recurring automation jobs
  - `manual` skills are the ones exposed by `ng`, grouped by directory
EOF
}

load_items_json() {
  "$LINKER" list --skills-root "$SKILLS_ROOT" --json "$@"
}

print_manual_list() {
  load_items_json --category manual | python3 -c '
import json, sys
data = json.load(sys.stdin)
items = data.get("items", [])
order = ("plan", "review", "research", "growth", "tooling", "meta")
groups = {name: [] for name in order}
for item in items:
    groups.setdefault(item.get("manual_group") or "other", []).append(item)

for group in [*order, *sorted(k for k in groups if k not in order)]:
    bucket = groups.get(group) or []
    if not bucket:
        continue
    print(f"# {group}")
    for item in bucket:
        skill_id = item["id"]
        path = item.get("path") or skill_id
        title = item.get("title") or skill_id
        summary = item.get("summary") or ""
        print(f"{group}\t{skill_id}\t{title}\t{summary}\t{path}")
'
}

print_category_plan() {
  load_items_json | python3 -c '
import json, sys
data = json.load(sys.stdin)
items = data.get("items", [])
groups = {"global": [], "cron": [], "auto": [], "manual": []}
for item in items:
    groups.setdefault(item.get("category", "manual"), []).append(item)

notes = {
    "global": "Install globally; auto-injected into agent instructions.",
    "cron": "Do not trigger manually; wire these into recurring automation jobs.",
    "auto": "Install once; they act as passive auto-trigger helpers.",
    "manual": "Use ng to list and choose these skills on demand.",
}

for category in ("global", "cron", "auto", "manual"):
    bucket = groups.get(category, [])
    print(f"[{category}] {notes[category]}")
    if not bucket:
        print("- none")
        print("")
        continue
    if category != "manual":
        for item in bucket:
            skill_id = item["id"]
            title = item.get("title") or skill_id
            print(f"- {skill_id}: {title}")
        print("")
        continue

    order = ("plan", "review", "research", "growth", "tooling", "meta")
    subgroups = {name: [] for name in order}
    for item in bucket:
        subgroups.setdefault(item.get("manual_group") or "other", []).append(item)
    for group in [*order, *sorted(k for k in subgroups if k not in order)]:
        members = subgroups.get(group) or []
        if not members:
            continue
        print(f"- {group}:")
        for item in members:
            skill_id = item["id"]
            title = item.get("title") or skill_id
            print(f"  - {skill_id}: {title}")
    print("")
'
}

print_skill_plan() {
  local skill_id="$1"
  load_items_json | python3 -c '
import json, sys

skill_id = sys.argv[1]
data = json.load(sys.stdin)
items = {item["id"]: item for item in data.get("items", [])}
item = items.get(skill_id)
if item is None:
    print(f"error: unknown skill id: {skill_id}", file=sys.stderr)
    raise SystemExit(1)

category = item.get("category", "manual")
manual_group = item.get("manual_group") or ""
title = item.get("title") or skill_id
summary = item.get("summary") or ""

print(f"Skill: {skill_id}")
print(f"Title: {title}")
print(f"Category: {category}")
if manual_group:
    print(f"Directory Group: {manual_group}")
if summary:
    print(f"Summary: {summary}")
print("")

if category == "manual":
    print("Trigger plan:")
    print(f"- Mention `{skill_id}` explicitly, or describe a task that matches its summary.")
    print(f"- Suggested prompt: Use the `{skill_id}` skill for this task.")
elif category == "global":
    print("Trigger plan:")
    print("- This is a global auto-trigger skill. Install it globally; do not invoke it manually.")
elif category == "auto":
    print("Trigger plan:")
    print("- This is an installed auto-trigger helper. Install it once; it should activate passively.")
elif category == "cron":
    print("Trigger plan:")
    print("- This skill is intended for recurring automation, not manual invocation.")
' "$skill_id"
}

pick_manual_skill() {
  if ! command -v fzf >/dev/null 2>&1; then
    print_manual_list
    return 0
  fi

  local choice
  choice="$(
    print_manual_list \
      | awk -F '\t' 'NF >= 4 {print}' \
      | fzf --with-nth=2,3 --delimiter=$'\t' \
          --prompt="ng>manual> " \
          --height=70% --layout=reverse --border --info=inline \
          --header="group | skill | title" \
          --preview 'cat "'"$SKILLS_ROOT"'"/{5}/SKILL.md 2>/dev/null || echo "No SKILL.md found"' \
          --preview-window 'right,60%,wrap'
  )" || return 1

  local skill_id
  skill_id="$(printf '%s' "$choice" | awk -F '\t' 'NF >= 2 {print $2}')"
  [[ -n "$skill_id" ]] || return 1
  print_skill_plan "$skill_id"
}

cmd="${1:-}"
case "$cmd" in
  "")
    pick_manual_skill
    ;;
  -h|--help|help)
    usage
    ;;
  list)
    print_manual_list
    ;;
  plan)
    print_category_plan
    ;;
  *)
    print_skill_plan "$cmd"
    ;;
esac
